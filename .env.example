# TradeOracle AI — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub!

# ══════════════════════════════
# REQUIRED — Bot won't start without these
# ══════════════════════════════
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=your_telegram_chat_id_here
ANTHROPIC_KEY=your_anthropic_api_key_here

# ══════════════════════════════
# EMAIL ALERTS (optional but recommended)
# ══════════════════════════════
GMAIL_SENDER=your_gmail@gmail.com
GMAIL_PASSWORD=your_16_digit_app_password

# ══════════════════════════════
# BOT BEHAVIOR (optional — defaults shown)
# ══════════════════════════════
SCAN_INTERVAL=15
MONITOR_INTERVAL=5
BRIEFING_TIME=08:00
WATCHLIST=NVDA,AAPL,MSFT,GOOGL,NFLX,AMZN,META,TSLA
MIN_PROFIT_ALERT=7
WARN_BUFFER=12
DANGER_BUFFER=5
EMERGENCY_BUFFER=3

# ══════════════════════════════
# HOW TO GET THESE VALUES
# ══════════════════════════════
# TELEGRAM_TOKEN:
#   1. Open Telegram
#   2. Search @BotFather
#   3. Send /newbot
#   4. Follow instructions
#   5. Copy the token given
#
# ADMIN_CHAT_ID:
#   1. Open Telegram
#   2. Search @userinfobot
#   3. Send /start
#   4. Copy your "Id" number
#
# ANTHROPIC_KEY:
#   1. Go to console.anthropic.com
#   2. Sign up / Login
#   3. API Keys → Create Key
#   4. Copy key starting with sk-ant-
#   5. Add billing credits ($10 minimum)
#
# GMAIL_PASSWORD:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (enable)
#   3. App passwords → Generate
#   4. Name: TradeOracle AI
#   5. Copy the 16-digit password
